{
    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#888888", // Top window bar
        "titleBar.inactiveBackground": "#88888899", // Top window bar inactive (add '99' to end of hex)
        "titleBar.activeForeground": "#f1cb13", // Top window bar - text
        "activityBarBadge.background": "#888888", // Side bar - badge icon background
        "activityBarBadge.foreground": "#f1cb13", // Side bar - badge text
        "activityBar.activeBorder": "#888888" // Side bar - active indicator border
    },
    "folder-color.pathColors": [
        {
            "folderPath": "package-lock.json/",
            "color": "foldercolorizer.olive"
        },
        {
            "folderPath": "package.json/",
            "color": "foldercolorizer.olive"
        },
        {
            "folderPath": ".gitignore/",
            "color": "foldercolorizer.OrangeRed"
        },
        {
            "folderPath": "src/assets/js/",
            "color": "foldercolorizer.Gold"
        },
        {
            "folderPath": "src/assets/partials/",
            "color": "foldercolorizer.LightBlue"
        },
        {
            "folderPath": "src/assets/scss/",
            "color": "foldercolorizer.LightPink"
        }
    ]
}